# Base URL of your running lemond server, including the OpenAI-compatible
# version prefix. Lemonade registers OpenAI-compatible routes under /api/v1.
# 13305 is Lemonade Server's default port; adjust host/port to match how you
# launched lemond. You can also set this in-app via the server-status menu.
LEMONADE_BASE_URL=http://localhost:13305/api/v1

# Optional. Only needed if you started lemond with LEMONADE_API_KEY set.
# Sent as `Authorization: Bearer <key>` on every request (REST and /mcp).
LEMONADE_API_KEY=

# Default model the agent uses for chat. Must be a model your lemond can serve
# (call the /api/v1/models endpoint, or lemonade_list_models, to see options).
LEMONADE_MODEL=Qwen3-1.7B-GGUF

# Safety rail: max tool-calling iterations per user turn before the loop stops.
AGENT_MAX_STEPS=8

# Prompt for confirmation before every MCP tool call. Set to "false" to let the
# agent run tools without asking (not recommended with untrusted servers).
AGENT_REQUIRE_APPROVAL=true

# Spoken replies (TTS) via lemond's /v1/audio/speech (Kokoro backend). Can be
# toggled live from the app's 🔊 button. LEMONADE_TTS_MODEL is treated as a
# preference: if it isn't served, the app auto-picks a model labeled "tts".
LEMONADE_TTS_ENABLED=false
LEMONADE_TTS_MODEL=kokoro-v1
LEMONADE_TTS_VOICE=af_sky
LEMONADE_TTS_FORMAT=mp3

LEMONADE_CONTEXT_SIZE=4096 # match the actual runtime budget (guarantees the warning fires correctly), or
# Relaunch the server with a larger context so it can actually use the model's 40960 window — then the filesystem-tool request fits easily.
LEMONADE_COMPLETION_RESERVE=512 # controls how many tokens are held back for the reply.

# Logging verbosity. Set to "debug" to print diagnostic traces (e.g. the TTS
# pipeline) to the terminal and the renderer console, and to auto-open DevTools.
# Any other value keeps logging quiet (errors still show).
LOG_LEVEL=info
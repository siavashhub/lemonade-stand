node_modules/
out/
out-types/
dist/
*.log
.DS_Store

# Bundled runtime binaries (uv/uvx) downloaded at build time by
# scripts/fetch-uv.mjs, platform-specific, never committed.
resources/bin/

# Local runtime config that may contain endpoints/keys, never commit.
.env
config/servers.local.json

# Per-user app state (active model, context size, etc.). The committed
# config/settings.json ships as a clean default; a developer's own choices are
# written to this gitignored local override so a dev checkout never commits
# machine-specific state (mirrors config/servers.local.json).
config/settings.local.json

# Per-developer Pitcher (scheduled task) edits layered over the committed
# config/pitchers.json default, so a dev checkout never commits local scheduled
# tasks (mirrors config/servers.local.json).
config/pitchers.local.json

# Conversation history written at runtime (dev: project root, packaged: %APPDATA%).
conversations/

# local tests
temp/

test